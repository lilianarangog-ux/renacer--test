// 📄 EXPORTACIÓN PDF — html2canvas + jsPDF
// Funciona en: Chrome PC, Chrome Android, Safari iPhone
// Sin window.print(), descarga directa, multipágina automático
// ══════════════════════════════════════════════════════════

function buildPDFHTML(r) {
  const t=T[r.top], wt=T[r.wing];
  const stL={cons:'Conservación',soc:'Social',sex:'Sexual'};
  const stI={cons:'🏠',soc:'👥',sex:'❤️'};
  const trL={mental:'Tríada Mental (5·6·7)',emocional:'Tríada Emocional (2·3·4)',visceral:'Tríada Visceral (8·9·1)'};
  const date=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'});
  const maxS=Math.max(...Object.values(r.sc));
  const bars=r.sorted.map(([tp,s])=>{
    const p=maxS>0?Math.round((s/maxS)*100):0;
    const isT=parseInt(tp)===r.top;
    return`<div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
      <span style="font-size:12px;width:130px;flex-shrink:0;color:${isT?t.cb:'#4a4a4a'};font-weight:${isT?700:400}">${T[tp].alias}</span>
      <div style="flex:1;height:6px;background:#e0dbd0;border-radius:3px">
        <div style="width:${p}%;height:6px;border-radius:3px;background:${isT?t.cb:'#ccc'}"></div>
      </div>
      <span style="font-size:11px;color:#888;width:36px;text-align:right;flex-shrink:0">${s} pts</span>
    </div>`;
  }).join('');

  return `
<div style="font-family:'Helvetica Neue',Arial,sans-serif;background:#fff;color:#0f0f0f;font-size:13px;line-height:1.7;padding:40px 44px;width:794px;box-sizing:border-box">

  <!-- HEADER -->
  <div style="background:${t.col};border-radius:14px;padding:30px 34px;margin-bottom:22px;border:1px solid ${t.cb}">
    <div style="font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:${t.ct};opacity:.7;margin-bottom:10px;font-weight:600">RENACER — 7 días para volver a ti · ${date}</div>
    <div style="font-size:56px;font-weight:700;color:${t.ct};line-height:1;margin-bottom:4px">${r.top}</div>
    <div style="font-size:26px;font-weight:600;color:${t.ct};margin-bottom:3px">${t.name}</div>
    <div style="font-size:12px;color:${t.ct};opacity:.7;margin-bottom:12px">${t.alias} · ${trL[t.triada]}</div>
    <div style="font-size:13px;color:${t.ct};opacity:.88;line-height:1.7">${t.herida.split('.')[0]}.</div>
  </div>

  <!-- PERFIL -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Tu perfil</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:22px">
    ${[['Nombre',user.name],['Fecha',date],['Miedo central',t.miedo],['Deseo profundo',t.deseo],['Ala dominante','Ala '+r.wing+' — '+wt.name],['Subtipo',stI[r.topSt]+' '+stL[r.topSt]],['Pasión',t.pasion],['Virtud',t.virtud]].map(([l,v])=>`
    <div style="background:#f7f4ef;border-radius:9px;padding:11px 13px">
      <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:#888;margin-bottom:3px;font-weight:600">${l}</div>
      <div style="font-size:12px;font-weight:500;color:#0f0f0f">${v}</div>
    </div>`).join('')}
  </div>

  <!-- HERIDA -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Herida y mecanismo de defensa</div>
  ${[['Herida emocional',t.herida],['Mecanismo de defensa',t.mecanismo],['En las relaciones',t.relaciones]].map(([l,v])=>`
  <div style="border-left:3px solid ${t.cb};padding-left:14px;margin-bottom:13px">
    <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:${t.cb};font-weight:700;margin-bottom:4px">${l}</div>
    <div style="font-size:12px;color:#4a4a4a;line-height:1.75">${v}</div>
  </div>`).join('')}

  <!-- INTEGRACIÓN -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Integración y desintegración</div>
  <div style="background:#f7f4ef;border-radius:9px;padding:14px 16px;margin-bottom:9px">
    <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:#1D9E75;font-weight:700;margin-bottom:6px">↑ EN CRECIMIENTO — Tipo ${t.int}: ${T[t.int].name}</div>
    <div style="font-size:12px;color:#4a4a4a;line-height:1.65;margin-bottom:7px">${t.intDesc}</div>
    ${t.signInt.map(s=>`<div style="font-size:12px;color:#1D9E75;padding:3px 0 3px 11px;border-left:2px solid #1D9E75;margin-bottom:3px">✓ ${s}</div>`).join('')}
  </div>
  <div style="background:#f7f4ef;border-radius:9px;padding:14px 16px;margin-bottom:22px">
    <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:#D85A30;font-weight:700;margin-bottom:6px">↓ BAJO ESTRÉS — Tipo ${t.des}: ${T[t.des].name}</div>
    <div style="font-size:12px;color:#4a4a4a;line-height:1.65;margin-bottom:7px">${t.desDesc}</div>
    ${t.signDes.map(s=>`<div style="font-size:12px;color:#D85A30;padding:3px 0 3px 11px;border-left:2px solid #D85A30;margin-bottom:3px">⚠ ${s}</div>`).join('')}
  </div>

  <!-- SUBTIPOS -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Subtipos instintivos</div>
  ${[['🏠 Conservación',t.st.cons],['👥 Social',t.st.soc],['❤️ Sexual / Uno a uno',t.st.sex]].map(([l,v])=>`
  <div style="background:#f7f4ef;border-radius:9px;padding:12px 15px;margin-bottom:8px">
    <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:${t.cb};font-weight:700;margin-bottom:5px">${l}</div>
    <div style="font-size:12px;color:#4a4a4a;line-height:1.65">${v}</div>
  </div>`).join('')}

  <!-- FORTALEZAS -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin:22px 0 12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Fortalezas y sombras</div>
  <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:${t.cb};font-weight:700;margin-bottom:7px">Fortalezas</div>
  <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
    ${t.fortalezas.map(f=>`<span style="padding:4px 11px;border-radius:20px;font-size:11px;border:1px solid ${t.cb};color:${t.cb}">${f}</span>`).join('')}
  </div>
  <div style="font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:#888;font-weight:700;margin-bottom:7px">Sombras</div>
  <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:22px">
    ${t.sombras.map(f=>`<span style="padding:4px 11px;border-radius:20px;font-size:11px;border:1px solid #ddd;color:#4a4a4a">${f}</span>`).join('')}
  </div>

  <!-- FRASES -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Frases que suelen resonar</div>
  ${t.frases.map(f=>`<div style="font-style:italic;font-size:13px;color:#4a4a4a;border-left:2px solid ${t.cb};padding-left:13px;margin-bottom:10px;line-height:1.65">"${f}"</div>`).join('')}

  <!-- RECOMENDACIONES -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin:22px 0 12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Recomendaciones de evolución</div>
  ${t.recomendaciones.map((rec,i)=>`
  <div style="background:#f7f4ef;border-radius:9px;padding:13px 15px;margin-bottom:9px">
    <div style="font-size:12px;font-weight:700;color:${t.cb};margin-bottom:4px">${i+1}. ${rec.t}</div>
    <div style="font-size:11px;color:#4a4a4a;line-height:1.7">${rec.d}</div>
  </div>`).join('')}

  <!-- DISTRIBUCIÓN -->
  <div style="font-size:15px;font-weight:700;color:#0f0f0f;margin:22px 0 12px;padding-bottom:6px;border-bottom:2px solid ${t.cb}">Distribución por tipo</div>
  ${bars}

  <!-- FOOTER -->
  <div style="text-align:center;margin-top:28px;padding-top:16px;border-top:1px solid #e0dbd0;font-size:10px;color:#aaa">
    RENACER — Test de Eneagrama · Perfil de ${user.name} · ${date}
  </div>
</div>`;
}

async function downloadPDF() {
  if (!result) return;

  const loading = document.getElementById('pdf-loading');
  const container = document.getElementById('pdf-export-container');

  // Mostrar loading
  loading.classList.add('active');

  try {
    // Renderizar HTML del perfil en el contenedor oculto
    container.innerHTML = buildPDFHTML(result);
    container.style.left = '-9999px';
    container.style.position = 'fixed';
    container.style.top = '0';
    container.style.width = '794px';
    document.body.appendChild(container);

    // Esperar un frame para que el DOM se pinte
    await new Promise(r => setTimeout(r, 300));

    // Capturar con html2canvas
    const canvas = await html2canvas(container, {
      scale: 2,                    // Calidad retina
      useCORS: true,
      allowTaint: true,
      backgroundColor: '#ffffff',
      logging: false,
      width: 794,
      windowWidth: 794
    });

    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({
      orientation: 'portrait',
      unit: 'pt',
      format: 'a4'
    });

    const pageW = pdf.internal.pageSize.getWidth();   // 595 pt
    const pageH = pdf.internal.pageSize.getHeight();  // 842 pt
    const margin = 0;

    const imgW = pageW - margin * 2;
    const ratio = canvas.width / imgW;
    const imgH = canvas.height / ratio;

    const imgData = canvas.toDataURL('image/jpeg', 0.92);

    // Multipágina automático: corta el canvas en trozos de pageH
    let yPos = 0;
    let pageNum = 0;

    while (yPos < imgH) {
      if (pageNum > 0) pdf.addPage();

      // Calcular cuánto del canvas entra en esta página
      const sliceH = Math.min(pageH, imgH - yPos);
      // Offset en píxeles del canvas original
      const srcY = yPos * ratio;
      const srcH = sliceH * ratio;

      // Crear canvas de la rebanada
      const sliceCanvas = document.createElement('canvas');
      sliceCanvas.width = canvas.width;
      sliceCanvas.height = srcH;
      const ctx = sliceCanvas.getContext('2d');
      ctx.drawImage(canvas, 0, srcY, canvas.width, srcH, 0, 0, canvas.width, srcH);

      const sliceData = sliceCanvas.toDataURL('image/jpeg', 0.92);
      pdf.addImage(sliceData, 'JPEG', margin, margin, imgW, sliceH);

      yPos += pageH;
      pageNum++;
    }

    // Nombre dinámico del archivo
    const nombreLimpio = user.name.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, '');
    const fileName = `RENACER_Eneagrama_${nombreLimpio}.pdf`;

    // Detección de Safari iOS — fallback a abrir en nueva pestaña
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);

    if (isIOS || isSafari) {
      // Safari no soporta blob download directo — abrir en nueva pestaña
      const pdfBlob = pdf.output('blob');
      const blobUrl = URL.createObjectURL(pdfBlob);
      const a = document.createElement('a');
      a.href = blobUrl;
      a.target = '_blank';
      a.rel = 'noopener';
      a.click();
      setTimeout(() => URL.revokeObjectURL(blobUrl), 5000);
    } else {
      // Chrome Android, Chrome PC, Firefox — descarga directa
      pdf.save(fileName);
    }

  } catch(err) {
    console.error('PDF error:', err);
    // Mensaje de error visual sin alert bloqueante
    const errDiv = document.createElement('div');
    errDiv.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:14px 22px;border-radius:10px;font-size:13px;z-index:99999;font-family:sans-serif;box-shadow:0 4px 20px rgba(0,0,0,.2)';
    errDiv.textContent = '⚠ No se pudo generar el PDF. Intenta de nuevo.';
    document.body.appendChild(errDiv);
    setTimeout(() => errDiv.remove(), 4000);
  } finally {
    // Limpiar contenedor y loading
    loading.classList.remove('active');
    container.innerHTML = '';
  }
}


// ══════════════════════════════════════════════════════════
// 🔐 SISTEMA DE LINK ÚNICO
// Valida el código en la URL contra Google Sheets
// ══════════════════════════════════════════════════════════

let codigoURL = new URLSearchParams(window.location.search).get('codigo') || '';
let linkValido = false;
let linkValidado = false;

function rBloqueadoUsado(nombre) {
  return `
<div style="text-align:center;padding:3rem 0 2rem">
  <div class="eyebrow">RENACER — 7 días para volver a ti</div>
  <div style="font-size:48px;margin:1.5rem 0">✦</div>
  <h1 style="font-family:var(--serif);font-size:clamp(26px,5vw,38px);margin-bottom:1rem;font-weight:400">
    ${nombre ? nombre + ', este link ya fue usado' : 'Este link ya fue usado'}
  </h1>
  <p style="font-size:15px;color:var(--ink2);line-height:1.8;margin-bottom:2rem;font-weight:300;max-width:440px;margin-left:auto;margin-right:auto">
    El test está diseñado para hacerse una sola vez. Si crees que hay un error, contacta a quien te compartió el link.
  </p>
  <div class="card" style="text-align:left;max-width:440px;margin:0 auto 1rem">
    <div class="card-label">¿Por qué una sola vez?</div>
    <div class="card-text">La primera respuesta instintiva es la más fiel a quien realmente eres. Repetirlo distorsiona los resultados.</div>
  </div>
</div>`;
}

function rBloqueadoExpirado(nombre) {
  return `
<div style="text-align:center;padding:3rem 0 2rem">
  <div class="eyebrow">RENACER — 7 días para volver a ti</div>
  <div style="font-size:48px;margin:1.5rem 0">⏳</div>
  <h1 style="font-family:var(--serif);font-size:clamp(26px,5vw,38px);margin-bottom:1rem;font-weight:400">
    ${nombre ? nombre + ', tu link expiró' : 'Este link expiró'}
  </h1>
  <p style="font-size:15px;color:var(--ink2);line-height:1.8;margin-bottom:2rem;font-weight:300;max-width:440px;margin-left:auto;margin-right:auto">
    Los links son válidos por 24 horas. Contacta a quien te lo envió para recibir uno nuevo.
  </p>
</div>`;
}

function rBloqueadoInvalido() {
  return `
<div style="text-align:center;padding:3rem 0 2rem">
  <div class="eyebrow">RENACER — 7 días para volver a ti</div>
  <div style="font-size:48px;margin:1.5rem 0">🔒</div>
  <h1 style="font-family:var(--serif);font-size:clamp(26px,5vw,38px);margin-bottom:1rem;font-weight:400">
    Acceso no válido
  </h1>
  <p style="font-size:15px;color:var(--ink2);line-height:1.8;margin-bottom:2rem;font-weight:300;max-width:440px;margin-left:auto;margin-right:auto">
    Este test requiere un link personalizado. Si adquiriste el test, revisa el mensaje que recibiste.
  </p>
</div>`;
}

function rValidando() {
  return `
<div style="text-align:center;padding:4rem 0">
  <div style="width:44px;height:44px;border:3px solid rgba(181,134,42,.25);border-top-color:#b5862a;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 1.5rem"></div>
  <p style="font-size:15px;color:var(--ink3);font-weight:300">Validando tu acceso…</p>
</div>`;
}

async function validarAcceso() {
  if (!codigoURL) {
    linkValido = false;
    linkValidado = true;
    render();
    return;
  }

  // Mostrar pantalla de validando
  document.getElementById('root').innerHTML = `<div class="wrap">${rValidando()}</div>`;

  try {
    const url = CONFIG.SCRIPT_URL + '?codigo=' + encodeURIComponent(codigoURL) + '&callback=cb_' + Date.now();
    await new Promise((resolve) => {
      const cbName = 'renacerCb_' + Date.now();
      const script = document.createElement('script');
      window[cbName] = function(data) {
        delete window[cbName];
        script.remove();
        if (data.valido) {
          linkValido = true;
          // Pre-rellenar nombre y email si vienen del link
          if (data.nombre) user.name = data.nombre;
          if (data.email) user.email = data.email;
        } else {
          linkValido = false;
          linkRazon = data.razon || 'invalido';
          linkNombre = data.nombre || '';
        }
        linkValidado = true;
        resolve();
      };
      script.src = CONFIG.SCRIPT_URL + '?codigo=' + encodeURIComponent(codigoURL) + '&callback=' + cbName;
      script.onerror = () => {
        // Si falla la red, dejar pasar (no bloquear por error de red)
        linkValido = true;
        linkValidado = true;
        resolve();
      };
      document.head.appendChild(script);
    });
  } catch(e) {
    linkValido = true; // fallback: si hay error de red, dejar pasar
    linkValidado = true;
  }

  render();
}

let linkRazon = '';
let linkNombre = '';

function yaCompletado() {
  // Solo bloquear en intro — nunca interrumpir el test ni el resultado
  if (phase === 'test' || phase === 'result') return false;
  if (!linkValidado) return false;
  if (!codigoURL) return true;
  if (!linkValido) return true;
  return false;
}

function rBloqueado() {
  if (!codigoURL) return rBloqueadoInvalido();
  if (linkRazon === 'ya_usado') return rBloqueadoUsado(linkNombre);
  if (linkRazon === 'expirado') return rBloqueadoExpirado(linkNombre);
  return rBloqueadoInvalido();
}
// ── RENDER ──
function render(){
  const root=document.getElementById('root');
  let h='';
  // Solo bloquear si estamos en intro Y el link no es válido
  if(phase==='intro' && linkValidado && (!codigoURL || !linkValido)){
    h=rBloqueado();
  } else if(phase==='intro')h=rIntro();
  else if(phase==='form')h=rForm();
  else if(phase==='test')h=rTest();
  else if(phase==='result')h=rResult();
  root.innerHTML=`<div class="wrap animate-in">${h}<div class="footer">${CONFIG.BRAND} · Uso personal</div></div>`;
  attachEvents();
}

function rIntro(){return`
<div class="eyebrow">RENACER — 7 días para volver a ti</div>
<h1>La arquitectura de tu <em>personalidad</em></h1>
<p class="hero-sub">El Eneagrama no mide rasgos superficiales — detecta los patrones inconscientes, heridas emocionales y miedos centrales que construiste antes de tener palabras para nombrarlos.</p>
<div class="card">
  <div class="card-label">Qué vas a descubrir</div>
  <div class="card-text">Tu eneatipo dominante, ala probable, subtipo instintivo, tríada, herida emocional, mecanismo de defensa, comportamiento bajo estrés y en crecimiento, fortalezas, sombras y recomendaciones personalizadas.</div>
</div>
<div class="card">
  <div class="card-label">Cómo responder</div>
  <div class="card-text">Responde desde cómo has sido durante la mayor parte de tu vida — no desde quien quieres ser ni desde quien crees que deberías ser. La incomodidad suele ser la señal de que vas por buen camino.</div>
</div>
<div class="card">
  <div class="card-label">Escala de respuestas</div>
  <div class="scale-row">
    ${[1,2,3,4,5].map((n,i)=>`<div class="sr-item"><div class="sr-n">${n}</div><div class="sr-l">${SCALE_LABELS[i]}</div></div>`).join('')}
  </div>
</div>
<div class="meta">33 preguntas · 8–12 minutos · ninguna respuesta es correcta ni incorrecta</div>
<button class="btn-main" id="start-btn">Comenzar →</button>`;}

function rForm(){return`
<h2 class="section-head">Antes de empezar</h2>
<p class="section-sub">Estos datos personalizan tu perfil y permiten guardar tus resultados.</p>
<div class="field"><label>Nombre completo</label><input id="f-name" type="text" placeholder="Tu nombre completo" value="${user.name}"></div>
<div class="field"><label>Correo electrónico</label><input id="f-email" type="email" placeholder="correo@ejemplo.com" value="${user.email}"></div>
<div class="field-row">
  <div class="field"><label>Edad</label><input id="f-age" type="number" placeholder="Ej: 32" min="16" max="99" value="${user.age}"></div>
  <div class="field"><label>Ocupación</label><input id="f-job" type="text" placeholder="Ej: Psicóloga" value="${user.job}"></div>
</div>
<div id="form-err" class="err-msg">Por favor completa todos los campos.</div>
<button class="btn-main" id="form-next">Comenzar el test →</button>
<button class="btn-sec" id="form-back">← Volver</button>`;}

function rTest(){
  const q=QS[cur];
  const pct=Math.round((cur/QS.length)*100);
  const sel=ans[cur];
  return`
<div class="prog-wrap">
  <div class="prog-top"><span class="prog-label">${cur+1} de ${QS.length}</span><span class="prog-pct">${pct}%</span></div>
  <div class="prog-track"><div class="prog-fill" style="width:${pct}%"></div></div>
</div>
<div class="q-tag">${q.d}</div>
<div class="q-text">${q.q}</div>
<div class="scale-btns">
  ${[1,2,3,4,5].map((n,i)=>`<button class="sb${sel===n?' sel':''}" data-v="${n}">
    <div class="sb-n">${n}</div>
    <div class="sb-l">${SCALE_LABELS[i]}</div>
  </button>`).join('')}
</div>
<div class="nav">
  <button class="nav-prev" id="prev-btn" ${cur===0?'disabled':''}>← Anterior</button>
  <button class="nav-next" id="next-btn" ${sel===null?'disabled':''}>
    ${cur<QS.length-1?'Siguiente →':'Ver mi perfil →'}
  </button>
</div>`;}

function rResult(){
  const r=result;
  const t=T[r.top],wt=T[r.wing];
  const stL={cons:'Conservación',soc:'Social',sex:'Sexual'};
  const stI={cons:'🏠',soc:'👥',sex:'❤️'};
  const trC={mental:'#378ADD',emocional:'#D4537E',visceral:'#D85A30'};
  const trL={mental:'Tríada Mental (5·6·7)',emocional:'Tríada Emocional (2·3·4)',visceral:'Tríada Visceral (8·9·1)'};
  const trDesc={
    mental:"Tu centro de gravedad es el pensamiento. Antes de sentir o actuar, tu mente analiza, anticipa y planifica.",
    emocional:"Tu centro son las emociones y el reconocimiento. Tu identidad está profundamente ligada a cómo eres visto y amado.",
    visceral:"Tu centro es el cuerpo y la voluntad. Sientes la vida en las tripas antes de pensarla."
  };
  const maxS=Math.max(...Object.values(r.sc));
  const maxSt=Math.max(...Object.values(r.st[r.top]),1);
  const bars=r.sorted.map(([tp,s])=>{
    const p=maxS>0?Math.round((s/maxS)*100):0;
    const isT=parseInt(tp)===r.top;
    return`<div class="srow">
      <span class="slbl" style="${isT?'color:var(--ink);font-weight:600':''}">${T[tp].alias}</span>
      <div class="strk"><div class="sfill" style="width:${p}%;background:${isT?t.cb:'var(--sand3)'}"></div></div>
      <span class="snum">${s}</span>
    </div>`;
  }).join('');
  const stBars=Object.entries(r.st[r.top]).map(([k,v])=>{
    const p=Math.round((v/maxSt)*100);
    const isT=k===r.topSt;
    return`<div class="srow">
      <span class="slbl" style="${isT?'font-weight:600;color:var(--ink)':''}">${stI[k]} ${stL[k]}</span>
      <div class="strk"><div class="sfill" style="width:${p}%;background:${isT?t.cb:'var(--sand3)'}"></div></div>
      <span class="snum">${v}</span>
    </div>`;
  }).join('');

  return`
<div class="res-hero" style="background:${t.col};border-color:${t.cb}">
  <div class="res-greeting" style="color:${t.ct}">Tu resultado, ${user.name}</div>
  <div class="res-num" style="color:${t.ct}">${r.top}</div>
  <div class="res-name" style="color:${t.ct}">${t.name}</div>
  <div class="res-alias" style="color:${t.ct}">${t.alias} · ${trL[t.triada]}</div>
  <p class="res-desc" style="color:${t.ct}">${t.herida.split('.')[0]}.</p>
</div>

<div class="rc">
  <div class="rc-title">Tu perfil completo</div>
  <div class="g2">
    <div class="cell"><div class="cl">Miedo central</div><div class="cv">${t.miedo}</div></div>
    <div class="cell"><div class="cl">Deseo profundo</div><div class="cv">${t.deseo}</div></div>
    <div class="cell"><div class="cl">En crecimiento</div><div class="cv" style="color:${T[t.int].cb}">→ Tipo ${t.int}: ${T[t.int].name}</div></div>
    <div class="cell"><div class="cl">Bajo estrés</div><div class="cv" style="color:${T[t.des].cb}">→ Tipo ${t.des}: ${T[t.des].name}</div></div>
    <div class="cell"><div class="cl">Ala dominante</div><div class="cv">Ala ${r.wing}: ${wt.name}</div></div>
    <div class="cell"><div class="cl">Subtipo</div><div class="cv">${stI[r.topSt]} ${stL[r.topSt]}</div></div>
    <div class="cell"><div class="cl">Pasión</div><div class="cv">${t.pasion}</div></div>
    <div class="cell"><div class="cl">Virtud</div><div class="cv">${t.virtud}</div></div>
  </div>
</div>

<div class="rc">
  <div class="rc-title" style="color:${trC[t.triada]}">${trL[t.triada]}</div>
  <p style="font-size:14px;color:var(--ink2);line-height:1.75;font-weight:300">${trDesc[t.triada]}</p>
</div>

<div class="rc">
  <div class="rc-title">Herida y mecanismo de defensa</div>
  <div class="def-block" style="border-left-color:${t.cb}"><div class="def-lbl" style="color:${t.cb}">Herida emocional</div><div class="def-txt">${t.herida}</div></div>
  <div class="def-block" style="border-left-color:${t.cb}"><div class="def-lbl" style="color:${t.cb}">Mecanismo de defensa</div><div class="def-txt">${t.mecanismo}</div></div>
  <div class="def-block" style="border-left-color:${t.cb}"><div class="def-lbl" style="color:${t.cb}">En las relaciones</div><div class="def-txt">${t.relaciones}</div></div>
</div>

<div class="rc">
  <div class="rc-title">Integración y desintegración</div>
  <div class="st-card">
    <div class="st-l" style="color:#1D9E75">↑ En crecimiento — hacia Tipo ${t.int}: ${T[t.int].name}</div>
    <div class="st-t" style="margin-bottom:.7rem">${t.intDesc}</div>
    ${t.signInt.map(s=>`<div class="sign-row" style="border-left-color:#1D9E75">✓ ${s}</div>`).join('')}
  </div>
  <div class="st-card">
    <div class="st-l" style="color:#D85A30">↓ Bajo estrés — hacia Tipo ${t.des}: ${T[t.des].name}</div>
    <div class="st-t" style="margin-bottom:.7rem">${t.desDesc}</div>
    ${t.signDes.map(s=>`<div class="sign-row" style="border-left-color:#D85A30">⚠ ${s}</div>`).join('')}
  </div>
</div>

<div class="rc">
  <div class="rc-title">Subtipo dominante: ${stI[r.topSt]} ${stL[r.topSt]}</div>
  <p style="font-size:14px;color:var(--ink2);line-height:1.7;margin-bottom:.85rem;font-weight:300">${t.st[r.topSt]}</p>
  <div class="sl">Distribución de subtipos</div>${stBars}
  <hr class="divider">
  <div class="sl">Los tres subtipos</div>
  ${['cons','soc','sex'].map(k=>`<div class="st-card"><div class="st-l" style="color:${t.cb}">${stI[k]} ${stL[k]}</div><div class="st-t">${t.st[k]}</div></div>`).join('')}
</div>

<div class="rc">
  <div class="rc-title">Fortalezas y sombras</div>
  <div class="sl">Fortalezas</div>
  <div class="tag-row">${t.fortalezas.map(f=>`<span class="tag" style="border-color:${t.cb};color:${t.cb}">${f}</span>`).join('')}</div>
  <div class="sl">Sombras</div>
  <div class="tag-row">${t.sombras.map(f=>`<span class="tag">${f}</span>`).join('')}</div>
</div>

<div class="rc">
  <div class="rc-title">Frases que suelen resonar</div>
  ${t.frases.map(f=>`<div class="quote">"${f}"</div>`).join('')}
</div>

<div class="rc">
  <div class="rc-title">Recomendaciones de evolución</div>
  ${t.recomendaciones.map(rec=>`<div class="rec"><div class="rec-t" style="color:${t.cb}">${rec.t}</div><div class="rec-d">${rec.d}</div></div>`).join('')}
</div>

<div class="rc">
  <div class="rc-title">Distribución por tipo</div>
  ${bars}
</div>

<button class="action-btn ab-primary" id="dl-btn">⬇ Descargar mi perfil en PDF</button>
<button class="action-btn ab-secondary" id="dl-txt-btn">📄 Descargar perfil en .txt</button>`;}

// ── EVENTOS ──
function attachEvents(){
  const $=id=>document.getElementById(id);
  if(phase==='intro'){
    $('start-btn').onclick=()=>{phase='form';render();window.scrollTo(0,0);};
  }
  if(phase==='form'){
    $('form-back').onclick=()=>{phase='intro';render();window.scrollTo(0,0);};
    $('form-next').onclick=async()=>{
      const n=$('f-name').value.trim(),e=$('f-email').value.trim(),
            a=$('f-age').value.trim(),j=$('f-job').value.trim();
      if(!n||!e||!a||!j){$('form-err').style.display='block';return;}
      $('form-err').style.display='none';
      user={name:n,email:e,age:a,job:j};
      ans=new Array(QS.length).fill(null);cur=0;phase='test';
      render();window.scrollTo(0,0);
    };
  }
  if(phase==='test'){
    document.querySelectorAll('.sb').forEach(b=>{
      b.onclick=()=>{
        ans[cur]=parseInt(b.dataset.v);
        document.querySelectorAll('.sb').forEach(x=>x.classList.remove('sel'));
        b.classList.add('sel');
        document.getElementById('next-btn').disabled=false;
        setTimeout(()=>{
          const nb=document.getElementById('next-btn');
          if(nb&&!nb.disabled)nb.click();
        },420);
      };
    });
    const nb=$('next-btn'),pb=$('prev-btn');
    if(nb)nb.onclick=()=>{
      if(ans[cur]===null)return;
      if(cur<QS.length-1){cur++;render();window.scrollTo(0,0);}
      else{
        result=calcScores();
        sendToSheet(result);
        marcarCompletado(user.name,'Tipo '+result.top+' \u2014 '+T[result.top].name);
        phase='result';render();window.scrollTo(0,0);
      }
    };
    if(pb)pb.onclick=()=>{if(cur>0){cur--;render();window.scrollTo(0,0);}};
  }
  if(phase==='result'){
    const dlBtn=$('dl-btn');
    const dlTxtBtn=$('dl-txt-btn');
    if(dlBtn)dlBtn.onclick=()=>{ downloadPDF(); };
    if(dlTxtBtn)dlTxtBtn.onclick=()=>{
      if(!result)return;
      const txt=buildTxt(result);
      const blob=new Blob([txt],{type:'text/plain;charset=utf-8'});
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');
      a.href=url;
      const nombre=user.name.toLowerCase().replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'');
      a.download='perfil_eneagrama_'+nombre+'.txt';
      document.body.appendChild(a);
      a.click();
      setTimeout(()=>{URL.revokeObjectURL(url);a.remove();},1000);
    };
  }
}

function mostrarPerfilMovil(){
  if(!result)return;
  const r=result;
  const t=T[r.top],wt=T[r.wing];
  const stL={cons:'Conservación',soc:'Social',sex:'Sexual'};
  const stI={cons:'🏠',soc:'👥',sex:'❤️'};
  const trL={mental:'Tríada Mental (5·6·7)',emocional:'Tríada Emocional (2·3·4)',visceral:'Tríada Visceral (8·9·1)'};
  const date=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'});
  const maxS=Math.max(...Object.values(r.sc));
  const bars=r.sorted.map(([tp,s])=>{
    const p=maxS>0?Math.round((s/maxS)*100):0;
    const isT=parseInt(tp)===r.top;
    return`<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px"><span style="font-size:12px;width:110px;flex-shrink:0;color:${isT?t.cb:'#4a4a4a'};font-weight:${isT?700:400}">${T[tp].alias}</span><div style="flex:1;height:5px;background:#e0dbd0;border-radius:3px"><div style="width:${p}%;height:5px;border-radius:3px;background:${isT?t.cb:'#ccc'}"></div></div><span style="font-size:11px;color:#888">${s}</span></div>`;
  }).join('');
  // Remove existing overlay if any
  const existing=document.getElementById('perfil-movil');
  if(existing)existing.remove();
  const perfil=document.createElement('div');
  perfil.id='perfil-movil';
  perfil.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:#fff;z-index:9999;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 14px 30px;font-family:system-ui,sans-serif;font-size:14px;color:#0f0f0f';
  perfil.innerHTML=`
    <button onclick="document.getElementById('perfil-movil').remove()" style="width:100%;padding:12px;background:#f0ebe3;color:#0f0f0f;border:none;border-radius:10px;font-size:13px;font-weight:600;margin-bottom:14px;cursor:pointer">← Volver al test</button>
    <div style="background:#fffbe6;border:1px solid #f0d060;border-radius:8px;padding:10px;margin-bottom:14px;font-size:12px;color:#7a6000;text-align:center">📱 Para guardar: toca <strong>Compartir ↑</strong> → <strong>"Imprimir"</strong> → icono PDF</div>
    <div style="background:${t.col};border-radius:12px;padding:20px;margin-bottom:14px;border:1px solid ${t.cb}">
      <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:${t.ct};opacity:.7;margin-bottom:8px">RENACER · ${date}</div>
      <div style="font-size:42px;font-weight:700;color:${t.ct};line-height:1">${r.top}</div>
      <div style="font-size:20px;font-weight:600;color:${t.ct};margin:4px 0 2px">${t.name}</div>
      <div style="font-size:11px;color:${t.ct};opacity:.7;margin-bottom:8px">${t.alias} · ${trL[t.triada]}</div>
      <div style="font-size:12px;color:${t.ct};opacity:.85;line-height:1.7">${t.herida.split('.')[0]}.</div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Tu perfil</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px">
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Nombre</div><div style="font-size:12px;font-weight:500">${user.name}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Fecha</div><div style="font-size:12px;font-weight:500">${date}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Miedo central</div><div style="font-size:12px;font-weight:500">${t.miedo}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Deseo profundo</div><div style="font-size:12px;font-weight:500">${t.deseo}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Ala dominante</div><div style="font-size:12px;font-weight:500">Ala ${r.wing} — ${wt.name}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Subtipo</div><div style="font-size:12px;font-weight:500">${stI[r.topSt]} ${stL[r.topSt]}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Pasión</div><div style="font-size:12px;font-weight:500">${t.pasion}</div></div>
        <div style="background:#f7f4ef;border-radius:8px;padding:9px"><div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:600;margin-bottom:3px">Virtud</div><div style="font-size:12px;font-weight:500">${t.virtud}</div></div>
      </div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Herida y mecanismo de defensa</div>
      <div style="border-left:3px solid ${t.cb};padding-left:12px;margin-bottom:10px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:3px">Herida emocional</div><div style="font-size:12px;color:#4a4a4a;line-height:1.7">${t.herida}</div></div>
      <div style="border-left:3px solid ${t.cb};padding-left:12px;margin-bottom:10px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:3px">Mecanismo de defensa</div><div style="font-size:12px;color:#4a4a4a;line-height:1.7">${t.mecanismo}</div></div>
      <div style="border-left:3px solid ${t.cb};padding-left:12px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:3px">En las relaciones</div><div style="font-size:12px;color:#4a4a4a;line-height:1.7">${t.relaciones}</div></div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Integración y desintegración</div>
      <div style="background:#f7f4ef;border-radius:8px;padding:12px;margin-bottom:8px"><div style="font-size:9px;text-transform:uppercase;color:#1D9E75;font-weight:700;margin-bottom:5px">↑ En crecimiento — Tipo ${t.int}: ${T[t.int].name}</div><div style="font-size:12px;color:#4a4a4a;margin-bottom:6px">${t.intDesc}</div>${t.signInt.map(s=>`<div style="font-size:12px;color:#1D9E75;padding:2px 0 2px 10px;border-left:2px solid #1D9E75;margin-bottom:3px">✓ ${s}</div>`).join('')}</div>
      <div style="background:#f7f4ef;border-radius:8px;padding:12px"><div style="font-size:9px;text-transform:uppercase;color:#D85A30;font-weight:700;margin-bottom:5px">↓ Bajo estrés — Tipo ${t.des}: ${T[t.des].name}</div><div style="font-size:12px;color:#4a4a4a;margin-bottom:6px">${t.desDesc}</div>${t.signDes.map(s=>`<div style="font-size:12px;color:#D85A30;padding:2px 0 2px 10px;border-left:2px solid #D85A30;margin-bottom:3px">⚠ ${s}</div>`).join('')}</div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Subtipos instintivos</div>
      <div style="background:#f7f4ef;border-radius:8px;padding:12px;margin-bottom:7px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:5px">🏠 Conservación</div><div style="font-size:12px;color:#4a4a4a">${t.st.cons}</div></div>
      <div style="background:#f7f4ef;border-radius:8px;padding:12px;margin-bottom:7px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:5px">👥 Social</div><div style="font-size:12px;color:#4a4a4a">${t.st.soc}</div></div>
      <div style="background:#f7f4ef;border-radius:8px;padding:12px"><div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:5px">❤️ Sexual</div><div style="font-size:12px;color:#4a4a4a">${t.st.sex}</div></div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Fortalezas y sombras</div>
      <div style="font-size:9px;text-transform:uppercase;color:${t.cb};font-weight:700;margin-bottom:5px">Fortalezas</div>
      <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px">${t.fortalezas.map(f=>`<span style="padding:4px 10px;border-radius:20px;font-size:11px;border:1px solid ${t.cb};color:${t.cb}">${f}</span>`).join('')}</div>
      <div style="font-size:9px;text-transform:uppercase;color:#888;font-weight:700;margin-bottom:5px">Sombras</div>
      <div style="display:flex;flex-wrap:wrap;gap:5px">${t.sombras.map(f=>`<span style="padding:4px 10px;border-radius:20px;font-size:11px;border:1px solid #ddd;color:#4a4a4a">${f}</span>`).join('')}</div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Frases que suelen resonar</div>
      ${t.frases.map(f=>`<div style="font-style:italic;font-size:13px;color:#4a4a4a;border-left:2px solid ${t.cb};padding-left:12px;margin-bottom:8px;line-height:1.6">"${f}"</div>`).join('')}
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Recomendaciones de evolución</div>
      ${t.recomendaciones.map((rec,i)=>`<div style="background:#f7f4ef;border-radius:8px;padding:12px;margin-bottom:8px"><div style="font-size:12px;font-weight:700;color:${t.cb};margin-bottom:4px">${i+1}. ${rec.t}</div><div style="font-size:11px;color:#4a4a4a;line-height:1.65">${rec.d}</div></div>`).join('')}
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:14px;font-weight:700;border-bottom:2px solid ${t.cb};padding-bottom:6px;margin-bottom:10px">Distribución por tipo</div>
      ${bars}
    </div>
    <div style="text-align:center;padding:16px 0;font-size:11px;color:#aaa;border-top:1px solid #e0dbd0;margin-bottom:14px">RENACER — Test de Eneagrama · Perfil de ${user.name} · ${date}</div>
    <button onclick="document.getElementById('perfil-movil').remove()" style="width:100%;padding:14px;background:#0f0f0f;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer">← Volver</button>
  `;
  document.body.appendChild(perfil);
  window.scrollTo(0,0);
  perfil.scrollTop=0;
}

function downloadPDFMobile(){
  // Ya no se usa — todo va por downloadPDF() unificado
  downloadPDF();
}


render();
validarAcceso();</script>
</body>
</html>
