<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RENACER — Test de Eneagrama</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://openfpcdn.io/fingerprintjs/v4/iife.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --serif:'Playfair Display',Georgia,serif;
  --sans:'Plus Jakarta Sans',system-ui,sans-serif;
  --ink:#0f0f0f;
  --ink2:#4a4a4a;
  --ink3:#888;
  --sand:#f7f4ef;
  --sand2:#ede9e1;
  --sand3:#e0dbd0;
  --gold:#b5862a;
  --gold2:#d4a846;
  --gold-light:#fdf6e3;
  --purple:#6b5ce7;
  --purple2:#5548d4;
  --purple-light:#f0eeff;
  --white:#ffffff;
  --border:#ddd8ce;
  --radius:12px;
  --radius-lg:18px;
  --shadow:0 4px 24px rgba(0,0,0,.07);
  --shadow-lg:0 12px 48px rgba(0,0,0,.12);
}
html{scroll-behavior:smooth}
body{
  font-family:var(--sans);
  background:var(--sand);
  color:var(--ink);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
  background-image:
    radial-gradient(circle at 15% 20%, rgba(181,134,42,.06) 0%, transparent 50%),
    radial-gradient(circle at 85% 80%, rgba(107,92,231,.05) 0%, transparent 50%);
}
.wrap{max-width:620px;margin:0 auto;padding:3rem 1.5rem 5rem}
.eyebrow{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:1.25rem;display:flex;align-items:center;gap:10px}
.eyebrow::before,.eyebrow::after{content:'';flex:1;height:1px;background:var(--border)}
h1{font-family:var(--serif);font-size:clamp(32px,7vw,50px);line-height:1.1;color:var(--ink);margin-bottom:1.25rem;font-weight:400}
h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:15px;color:var(--ink2);line-height:1.8;margin-bottom:2rem;font-weight:300}
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.4rem 1.6rem;margin-bottom:.85rem;box-shadow:var(--shadow)}
.card-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:.6rem}
.card-text{font-size:14px;color:var(--ink2);line-height:1.8;font-weight:300}
.scale-row{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:1rem 0 .5rem}
.sr-item{background:var(--sand);border:1px solid var(--border);border-radius:10px;padding:12px 4px;text-align:center}
.sr-n{font-family:var(--serif);font-size:20px;color:var(--gold);margin-bottom:4px;line-height:1}
.sr-l{font-size:9.5px;color:var(--ink3);line-height:1.3}
.meta{font-size:12.5px;color:var(--ink3);text-align:center;margin-bottom:1.75rem;padding:10px;background:var(--sand2);border-radius:8px;letter-spacing:.2px}
.btn-main{width:100%;padding:16px;border:none;border-radius:var(--radius);font-size:15px;font-family:var(--sans);cursor:pointer;font-weight:600;background:var(--ink);color:var(--white);letter-spacing:.3px;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:10px;margin-top:.5rem}
.btn-main:hover{background:#333;transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.18)}
.btn-main:active{transform:translateY(0)}
.btn-sec{width:100%;padding:14px;border:1.5px solid var(--border);border-radius:var(--radius);font-size:14px;font-family:var(--sans);cursor:pointer;font-weight:500;background:var(--white);color:var(--ink2);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:.5rem}
.btn-sec:hover{background:var(--sand);border-color:var(--sand3)}
.section-head{font-family:var(--serif);font-size:28px;color:var(--ink);margin-bottom:.4rem;font-weight:400}
.section-sub{font-size:14px;color:var(--ink3);margin-bottom:1.75rem;line-height:1.7;font-weight:300}
.field{margin-bottom:1.1rem}
.field label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--ink3);margin-bottom:7px;font-weight:600}
.field input,.field select{
  width:100%;padding:13px 16px;
  border:1.5px solid var(--border);
  border-radius:var(--radius);
  font-size:15px;font-family:var(--sans);
  color:var(--ink);background:var(--white);
  transition:all .15s;font-weight:300;
  appearance:none;
}
.field input:focus,.field select:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(181,134,42,.1)}
.field input::placeholder{color:var(--ink3)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.err-msg{color:#c0392b;font-size:12.5px;margin-bottom:.75rem;display:none;padding:10px 14px;background:#fdf0ef;border-radius:8px;border-left:3px solid #c0392b}
.prog-wrap{margin-bottom:2rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.prog-label{font-size:12.5px;color:var(--ink3);font-weight:500}
.prog-pct{font-size:12.5px;font-weight:700;color:var(--gold)}
.prog-track{height:2px;background:var(--border);border-radius:2px}
.prog-fill{height:2px;border-radius:2px;background:linear-gradient(90deg,var(--gold),var(--gold2));transition:width .5s cubic-bezier(.4,0,.2,1)}
.q-tag{display:inline-block;font-size:10px;padding:4px 12px;border-radius:20px;background:var(--gold-light);color:var(--gold);font-weight:600;letter-spacing:.5px;margin-bottom:1rem;border:1px solid rgba(181,134,42,.2)}
.q-text{font-family:var(--serif);font-size:clamp(17px,3.5vw,21px);color:var(--ink);line-height:1.55;margin-bottom:2rem;font-weight:400}
.scale-btns{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin-bottom:2rem}
.sb{
  background:var(--white);border:1.5px solid var(--border);
  border-radius:var(--radius);padding:16px 5px;
  cursor:pointer;text-align:center;
  transition:all .15s;display:flex;flex-direction:column;align-items:center;gap:6px;
  -webkit-tap-highlight-color:transparent;
}
.sb:hover{border-color:var(--gold2);background:var(--gold-light)}
.sb.sel{border-color:var(--gold);background:var(--gold-light);border-width:2px;box-shadow:0 0 0 3px rgba(181,134,42,.1)}
.sb-n{font-family:var(--serif);font-size:22px;color:var(--ink);line-height:1;transition:color .15s}
.sb.sel .sb-n{color:var(--gold)}
.sb-l{font-size:9.5px;color:var(--ink3);line-height:1.3}
.nav{display:flex;gap:10px;align-items:center}
.nav-prev{border:1.5px solid var(--border);border-radius:var(--radius);padding:12px 20px;font-size:13.5px;font-family:var(--sans);cursor:pointer;background:var(--white);color:var(--ink2);transition:all .15s;font-weight:500;white-space:nowrap}
.nav-prev:hover:not(:disabled){background:var(--sand)}
.nav-prev:disabled{opacity:.3;cursor:default}
.nav-next{flex:1;border:none;border-radius:var(--radius);padding:13px;font-size:14px;font-family:var(--sans);cursor:pointer;background:var(--ink);color:var(--white);transition:all .15s;font-weight:600}
.nav-next:hover:not(:disabled){background:#333}
.nav-next:disabled{opacity:.3;cursor:default}
.res-hero{border-radius:var(--radius-lg);padding:2.25rem;margin-bottom:1rem;border:1px solid transparent;position:relative;overflow:hidden}
.res-hero::after{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,.08);pointer-events:none}
.res-greeting{font-size:11px;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:.6rem;opacity:.8;font-weight:600}
.res-num{font-family:var(--serif);font-size:64px;line-height:1;margin-bottom:.2rem}
.res-name{font-family:var(--serif);font-size:30px;margin-bottom:.2rem;font-weight:400}
.res-alias{font-size:13px;margin-bottom:1.25rem;opacity:.7;letter-spacing:.3px}
.res-desc{font-size:14px;line-height:1.8;opacity:.88;font-weight:300}
.rc{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.6rem;margin-bottom:.85rem;box-shadow:var(--shadow)}
.rc-title{font-family:var(--serif);font-size:21px;color:var(--ink);margin-bottom:1rem;font-weight:400}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.cell{background:var(--sand);border-radius:10px;padding:13px 15px}
.cl{font-size:10px;color:var(--ink3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;font-weight:600}
.cv{font-size:13px;font-weight:500;color:var(--ink);line-height:1.4}
.sl{font-size:10px;color:var(--ink3);text-transform:uppercase;letter-spacing:.7px;margin:.9rem 0 .5rem;font-weight:600}
.def-block{border-left:2px solid var(--border);padding-left:14px;margin-bottom:.85rem}
.def-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;font-weight:700}
.def-txt{font-size:13.5px;color:var(--ink2);line-height:1.75;font-weight:300}
.st-card{background:var(--sand);border-radius:10px;padding:14px 16px;margin-bottom:7px}
.st-l{font-size:10px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;font-weight:700}
.st-t{font-size:13px;color:var(--ink2);line-height:1.65;font-weight:300}
.srow{display:flex;align-items:center;gap:10px;margin-bottom:7px}
.slbl{font-size:12px;width:120px;color:var(--ink2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0;font-weight:400}
.strk{flex:1;height:4px;background:var(--border);border-radius:3px}
.sfill{height:4px;border-radius:3px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.snum{font-size:11px;color:var(--ink3);width:24px;text-align:right;flex-shrink:0}
.tag-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:.5rem}
.tag{padding:5px 13px;border-radius:20px;font-size:12px;border:1px solid var(--border);color:var(--ink2);background:var(--white);font-weight:400}
.quote{font-family:var(--serif);font-style:italic;font-size:15px;color:var(--ink2);border-left:2px solid var(--gold);padding-left:14px;margin-bottom:12px;line-height:1.6}
.rec{background:var(--sand);border-radius:10px;padding:14px 16px;margin-bottom:8px}
.rec-t{font-size:13.5px;font-weight:600;color:var(--ink);margin-bottom:5px}
.rec-d{font-size:13px;color:var(--ink2);line-height:1.65;font-weight:300}
.sign-row{font-size:13px;color:var(--ink2);padding:5px 0 5px 13px;margin-bottom:5px;line-height:1.5;border-left:2px solid;font-weight:300}
.divider{border:none;border-top:1px solid var(--border);margin:1rem 0}
.action-btn{width:100%;border-radius:var(--radius);padding:15px;font-size:14.5px;font-family:var(--sans);cursor:pointer;font-weight:600;display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:.6rem;transition:all .2s;border:1.5px solid transparent;letter-spacing:.2px}
.action-btn:active{transform:scale(.98)}
.ab-primary{background:var(--ink);color:var(--white);border-color:var(--ink)}
.ab-primary:hover{background:#333}
.ab-secondary{background:var(--white);color:var(--ink2);border-color:var(--border)}
.ab-secondary:hover{background:var(--sand)}
.footer{text-align:center;padding:2.5rem 0 1rem;font-size:11.5px;color:var(--ink3);letter-spacing:.2px}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
/* ── PDF LOADING OVERLAY ── */
#pdf-loading{display:none;position:fixed;inset:0;background:rgba(15,15,15,.82);z-index:99999;flex-direction:column;align-items:center;justify-content:center;gap:20px}
#pdf-loading.active{display:flex}
.pdf-spinner{width:44px;height:44px;border:3px solid rgba(181,134,42,.25);border-top-color:#b5862a;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.pdf-loading-txt{font-family:var(--sans);font-size:14px;color:#fff;font-weight:500;letter-spacing:.3px}
.pdf-loading-sub{font-family:var(--sans);font-size:12px;color:rgba(255,255,255,.55);font-weight:300}
/* ── CONTENEDOR INVISIBLE PARA EXPORTAR ── */
#pdf-export-container{position:fixed;left:-9999px;top:0;width:794px;background:#fff;z-index:-1;font-family:'Helvetica Neue',Arial,sans-serif}
.animate-in{animation:fadeUp .4s ease forwards}
@media(max-width:480px){
  .field-row{grid-template-columns:1fr}
  .g2{grid-template-columns:1fr}
  .scale-btns{gap:5px}
  .sb{padding:12px 3px}
  .sb-n{font-size:19px}
  .sb-l{font-size:9px}
  .wrap{padding:2rem 1.1rem 4rem}
}
</style>
</head>
<body>
<div id="root"></div>
<!-- Overlay de loading PDF -->
<div id="pdf-loading">
  <div class="pdf-spinner"></div>
  <div class="pdf-loading-txt">Generando tu perfil PDF…</div>
  <div class="pdf-loading-sub">Esto puede tomar unos segundos</div>
</div>
<!-- Contenedor oculto para exportación -->
<div id="pdf-export-container"></div>

<script>
// ══════════════════════════════════════════════════════════
// ⚙️  CONFIGURACIÓN
// ══════════════════════════════════════════════════════════
const CONFIG = {
  SHEET_URL: "https://script.google.com/macros/s/AKfycbwlsumx9dY5VU4vEKzA1YO2D1xa_AG3fVQBLgn1awX49dny6OtfzHR3MztpsKOrsalk/exec",
  SCRIPT_URL: "https://script.google.com/macros/s/AKfycbwlsumx9dY5VU4vEKzA1YO2D1xa_AG3fVQBLgn1awX49dny6OtfzHR3MztpsKOrsalk/exec",
  BRAND: "RENACER — Test de Eneagrama"
};

// ── TIPOS ──
const T={
1:{name:"El Perfeccionista",alias:"El Reformador",triada:"visceral",col:"#E8F7F0",ct:"#085041",cb:"#1D9E75",
  int:7,des:4,pasion:"Ira contenida",virtud:"Serenidad",
  miedo:"Ser corrupto, defectuoso o malvado",deseo:"Ser íntegro, bueno y tener la razón",
  herida:"Sentiste desde pequeño que debías ser bueno para ser amado. El error no era un tropiezo — era una amenaza a tu valor como persona.",
  mecanismo:"Formación reactiva: transforma impulsos inaceptables en su opuesto. El enojo se vuelve paciencia forzada. El deseo se convierte en disciplina.",
  relaciones:"Eres leal y comprometido, pero puedes ser crítico y exigente. Tiendes a corregir más que a celebrar. Necesitas aprender a amar lo imperfecto.",
  intDesc:"En crecimiento aparece una ligereza que normalmente te niegas. Puedes disfrutar sin justificarte y reírte de ti mismo con genuina ternura.",
  desDesc:"Bajo estrés caes en melancolía y el sentido de ser fundamentalmente defectuoso. Te aíslas y pierdes tu capacidad de actuar.",
  signInt:["Puedes equivocarte sin hundirte","Disfrutas el presente sin agenda","Ríes de tus propias imperfecciones"],
  signDes:["Te vuelves hipersensible e incomprendido","La autocrítica se vuelve paralizante","Sientes que algo en ti está fundamentalmente roto"],
  fortalezas:["Integridad profunda","Sentido del deber","Ética genuina","Perseverancia","Atención al detalle"],
  sombras:["Rigidez","Autocrítica destructiva","Resentimiento reprimido","Hipercrítica hacia otros","Dificultad para relajarse"],
  frases:["Había una manera correcta de hacerlo y no se hizo.","No puedo descansar sabiendo que algo está mal.","Me exijo porque sé que puedo dar más."],
  recomendaciones:[
    {t:"Practica la autocompasión activa",d:"El error no define tu valor. Date el mismo permiso que le darías a alguien que amas profundamente."},
    {t:"Distingue la crítica del juicio",d:"Señalar que algo puede mejorar es útil. Condenar es completamente distinto."},
    {t:"Conecta con tu cuerpo",d:"Tu tensión se acumula físicamente. El movimiento y la respiración son medicinas reales para ti."}
  ],
  st:{cons:"Preocupación ansiosa: Canaliza la perfección hacia su propio mundo — cuerpo, casa, salud, finanzas. Muy rígido en sus rutinas. Su angustia se acumula adentro.",
     soc:"Inadaptabilidad: El reformador social que señala lo que está mal en el sistema. Su ira es indignación moral dirigida hacia el mundo externo.",
     sex:"Celo: La perfección se vuelve pasión hacia la pareja. Quiere transformar e impulsar al otro. El más intenso del tipo 1."}
},
2:{name:"El Ayudador",alias:"El Altruista",triada:"emocional",col:"#FDF3E3",ct:"#633806",cb:"#BA7517",
  int:4,des:8,pasion:"Orgullo",virtud:"Humildad",
  miedo:"Ser indigno de amor o innecesario",deseo:"Sentirse amado, valorado y necesitado",
  herida:"Aprendiste que el amor se gana sirviéndolo. En algún momento sentiste que solo eras bienvenido cuando eras útil.",
  mecanismo:"Represión: suprime sus propias necesidades para enfocarse en las de los demás, creyendo que eso mantiene el amor y la conexión.",
  relaciones:"Eres cálido e intuitivo, pero puedes volverte posesivo o resentido cuando sientes que no recibes lo que diste. Tu generosidad a veces esconde una cuenta pendiente.",
  intDesc:"En crecimiento puedes conectar con tus emociones más profundas sin necesitar que otros las validen. Descubres quién eres más allá de tu función.",
  desDesc:"Bajo estrés te vuelves agresivo y controlador. Exiges lo que sientes que te deben con una intensidad que puede destruir relaciones.",
  signInt:["Puedes recibir sin sentirte en deuda","Reconoces tus emociones antes de servir las ajenas","Dices no sin culpa paralizante"],
  signDes:["Tu generosidad se vuelve manipulación velada","Exiges reconocimiento con intensidad creciente","El resentimiento silencioso te consume"],
  fortalezas:["Empatía profunda","Calor genuino","Intuición emocional","Generosidad real","Capacidad de cuidar"],
  sombras:["Necesidad de ser necesitado","Dificultad para recibir","Resentimiento oculto","Manipulación inconsciente","Pérdida de identidad propia"],
  frases:["Lo hago porque me importa, no porque espere algo.","¿Por qué nadie pregunta cómo estoy yo?","Cuando estoy bien, todos están bien."],
  recomendaciones:[
    {t:"Aprende a recibir",d:"Aceptar ayuda no es debilidad — es confianza. Y confiar es la forma más profunda de amar."},
    {t:"Pregúntate qué necesitas tú",d:"Antes de preguntar qué necesitan los demás, hazte esa pregunta a ti mismo. Es el primer acto de amor propio real."},
    {t:"Revisa tus expectativas ocultas",d:"Cuando das esperando algo de vuelta, no es generosidad — es una transacción disfrazada. La diferencia importa."}
  ],
  st:{cons:"Privilegio: Cuida con intensidad pero espera un trato preferencial a cambio. Mezcla generosidad con demanda de reconocimiento.",
     soc:"Ambición: Se conecta con personas influyentes y obtiene poder a través de su utilidad. El más orientado al estatus del tipo 2.",
     sex:"Seducción: Se vuelve irresistible para la persona elegida. Su amor es intenso y a veces asfixiante. Quiere ser el centro del mundo del otro."}
},
3:{name:"El Triunfador",alias:"El Logrador",triada:"emocional",col:"#FFF8E7",ct:"#5C3A00",cb:"#D4900A",
  int:6,des:9,pasion:"Engaño",virtud:"Autenticidad",
  miedo:"Ser un fracaso o carecer de valor",deseo:"Ser exitoso, admirado y valioso",
  herida:"Aprendiste que el amor venía por lo que lograba, no por lo que era. Te convertiste en tu desempeño.",
  mecanismo:"Identificación: se funde con sus roles y logros hasta perder contacto con su esencia real. La imagen se vuelve la identidad.",
  relaciones:"Eres magnético y eficiente, pero puedes sacrificar la intimidad por la imagen. Tu pareja puede sentir que ama a la versión pública de ti, no a quien eres en privado.",
  intDesc:"En crecimiento puedes ser profundamente leal, cooperativo y presente sin necesitar el protagonismo ni el reconocimiento.",
  desDesc:"Bajo estrés te disocías, te vuelves apático y evitas cualquier responsabilidad como si de repente nada importara.",
  signInt:["Puedes estar presente sin agenda","La lealtad importa más que el reconocimiento","Tu valor no depende de lo que produces"],
  signDes:["Te desconectas emocionalmente de todo","La procrastinación reemplaza la acción","Te vuelves invisible para evitar el fracaso"],
  fortalezas:["Capacidad de ejecución","Adaptabilidad","Carisma natural","Energía y determinación","Visión de resultados"],
  sombras:["Vacío de identidad","Adicción al logro","Dificultad para ser vulnerable","Imagen sobre sustancia","Competitividad dañina"],
  frases:["Si no estoy produciendo, siento que no existo.","Me resulta difícil saber qué siento realmente.","Necesito que vean lo que hice, no solo lo que soy."],
  recomendaciones:[
    {t:"Pregúntate quién eres sin tus logros",d:"No para asustarte, sino para encontrar la parte de ti que nadie puede quitarte porque nunca tuvo que ganarse."},
    {t:"Practica la vulnerabilidad elegida",d:"Mostrar que no sabes, que tienes miedo o que necesitas ayuda no daña tu imagen — la hace humana y real."},
    {t:"Desacelera deliberadamente",d:"El espacio vacío no es improductivo. A veces es donde aparece lo que más importa."}
  ],
  st:{cons:"Vanidad de seguridad: Acumula logros como escudo contra la inseguridad. Muy orientado a la imagen personal y material.",
     soc:"Prestigio: El éxito es social. Títulos, reconocimiento público y reputación son su moneda. El más orientado al estatus.",
     sex:"Masculinidad/Feminidad: Proyecta la imagen ideal de lo que debe ser atractivo para la persona deseada. El más camaleónico del tipo 3."}
},
4:{name:"El Individualista",alias:"El Romántico",triada:"emocional",col:"#F3EEFF",ct:"#3A1A6E",cb:"#7B4FC9",
  int:1,des:2,pasion:"Envidia",virtud:"Ecuanimidad",
  miedo:"No tener identidad propia o carecer de significado",deseo:"Encontrarse a sí mismo y su significado único",
